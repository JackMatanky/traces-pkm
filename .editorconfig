# -----------------------------------------------------------------------------
# Filename:     traces-pkm/.editorconfig
# Docs:         https://editorconfig.org
# Spec:         https://spec.editorconfig.org/
# Description:  General formatting rules for configuration and documentation
#               files for Traces PKM.
# -----------------------------------------------------------------------------

root = true

# ------------------------------------------------------------ #
#                       Default Settings                       #
# ------------------------------------------------------------ #
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# ------------------------------------------------------------- #
#                             Rust                              #
# ------------------------------------------------------------- #
[*.rs]
indent_size = 4

# ------------------------------------------------------------- #
#                             TOML                              #
# ------------------------------------------------------------- #
[*.toml]
indent_size = 4

# ------------------------------------------------------------- #
#                          JSON & YAML                          #
# ------------------------------------------------------------- #
[*.{json,yaml,yml}]
indent_size = 2

# ------------------------------------------------------------- #
#                            Markdown                           #
# ------------------------------------------------------------- #
[*.md]
trim_trailing_whitespace = false
