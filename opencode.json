{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "adrs": {
      "command": [
        "adrs",
        "mcp",
        "serve"
      ],
      "cwd": "/Users/jack/Documents/41_personal/traces-pkm/",
      "enabled": true,
      "environment": {
        "ADR_DIRECTORY": "docs/adr/"
      },
      "type": "local"
    },
    "rust-docs": {
      "command": [
        "rust-docs-mcp"
      ],
      "enabled": true,
      "environment": {
        "RUST_DOCS_MCP_CACHE_DIR": ".rust-docs/cache/"
      },
      "type": "local"
    }
  }
}
